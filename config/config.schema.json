{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/RoAppeal/rbx-enforcement-ban-tool/main/config/config.schema.json",
  "title": "RoAppeal OSS configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "test_mode": {
      "type": "boolean",
      "default": false,
      "description": "Run the local dashboard with in-memory sample data and skip external service calls."
    },
    "accounts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["username", "email"],
        "anyOf": [{ "required": ["app_password"] }, { "required": ["gmail_app_password"] }],
        "properties": {
          "username": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "app_password": {
            "$ref": "#/$defs/secret",
            "description": "IMAP app password (Gmail or Outlook/Microsoft). Use an env: reference."
          },
          "gmail_app_password": {
            "$ref": "#/$defs/secret",
            "description": "Deprecated alias for app_password."
          },
          "imap_server": {
            "type": "string",
            "minLength": 1,
            "description": "Override the IMAP host. Auto-detected for Gmail and Outlook/Microsoft."
          },
          "imap_port": {
            "$ref": "#/$defs/tcpPort"
          }
        }
      }
    },
    "captcha": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "api_key"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["2captcha", "cds", "cds-solver", "funbypass"]
        },
        "api_key": {
          "$ref": "#/$defs/secret"
        }
      }
    },
    "ai": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "api_key"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["gateway", "groq"],
          "default": "groq",
          "description": "AI backend. Groq is recommended; gateway uses Vercel AI Gateway."
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "api_key": {
          "$ref": "#/$defs/secret"
        }
      }
    },
    "check_interval_minutes": {
      "type": "number",
      "minimum": 1
    },
    "rejection_wait_minutes": {
      "type": "number",
      "minimum": 1
    },
    "same_email_submission_delay_minutes": {
      "type": "number",
      "minimum": 0,
      "default": 5,
      "description": "Minimum minutes between appeal submissions that use the same email inbox. This keeps Roblox confirmation and support-ticket responses attributable to the correct account."
    },
    "dashboard": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "port": {
          "$ref": "#/$defs/tcpPort"
        },
        "require_password": {
          "type": "boolean",
          "default": false,
          "description": "Require a password to view the dashboard. Defaults to false (no login)."
        },
        "password": {
          "$ref": "#/$defs/secret"
        },
        "discord_webhook_url": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(env:[A-Za-z_][A-Za-z0-9_]*|https://(discord\\.com|discordapp\\.com)/api/webhooks/\\d+/[\\w-]+)$"
        }
      }
    }
  },
  "if": {
    "properties": {
      "test_mode": {
        "const": true
      }
    },
    "required": ["test_mode"]
  },
  "then": {},
  "else": {
    "required": ["accounts", "captcha", "ai"]
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "test_mode": {
            "not": {
              "const": true
            }
          },
          "dashboard": {
            "properties": {
              "enabled": {
                "const": true
              },
              "require_password": {
                "const": true
              }
            },
            "required": ["enabled", "require_password"]
          }
        },
        "required": ["dashboard"]
      },
      "then": {
        "properties": {
          "dashboard": {
            "required": ["password"]
          }
        }
      }
    }
  ],
  "$defs": {
    "secret": {
      "type": "string",
      "minLength": 1,
      "description": "Use either a literal secret or an env:VARIABLE reference."
    },
    "tcpPort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    }
  }
}
